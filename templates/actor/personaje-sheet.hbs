<form class="undavar-sheet personaje" autocomplete="off">

  <header class="sheet-header">
    <div class="header-izquierda">
      <img class="actor-imagen" src="{{actor.img}}" data-edit="img" title="{{actor.name}}">
      <div class="nombre-bloque">
        <input type="text" class="actor-nombre-input" name="actor-name" value="{{actor.name}}" placeholder="Nombre del personaje">
        <div class="rango-display">{{calc.rango}}</div>
        <div class="pv-bloque">
          <label>PV (#)</label>
          <input type="number" name="system.pv.value" value="{{actor.system.pv.value}}" min="0" max="564">
          <span class="pv-max">/ 564</span>
        </div>
      </div>
    </div>
    <div class="header-tiradas">
      <button type="button" class="roll-estandar" data-label="Tirada estándar"><i class="fas fa-dice-d6"></i> Tirada</button>
      <button type="button" class="roll-ataque" data-label="Ataque"><i class="fas fa-fist-raised"></i> Ataque</button>
      <button type="button" class="roll-rebote"><i class="fas fa-bolt"></i> Rebote</button>
      <button type="button" class="roll-despertar"><i class="fas fa-sun"></i> Despertar</button>
    </div>
  </header>

  <section class="estado-atributos-bar">

    <div class="bloque-estado">
      <div class="bloque-titulo">Estado</div>
      <div class="estado-fila">
        <label>Pt. Herida</label>
        <input type="number" name="system.estado.ptHerida.value" value="{{actor.system.estado.ptHerida.value}}" min="0" max="8">
        <span class="estado-max">/8</span>
        {{#if calc.bonusHeridas}}<span class="aviso-herida">(+{{calc.bonusHeridas}} por estado = {{calc.heridasTotales}} Totales)</span>{{/if}}
      </div>
      <div class="estado-fila">
        <label>Pt. Salud</label>
        <input type="number" name="system.estado.ptSalud.value" value="{{actor.system.estado.ptSalud.value}}" min="0" max="{{actor.system.estado.ptSalud.max}}">
        <span class="estado-max">/8</span>
        {{#if calc.saludPorHeridas}}<span class="aviso-herida">(-{{calc.saludPorHeridas}} por heridas)</span>{{/if}}
      </div>
      <div class="estado-fila">
        <label>PA</label>
        <input type="number" name="system.pa.value" value="{{actor.system.pa.value}}" min="0" max="{{calc.paMaximo}}">
        <span class="estado-max">/{{calc.paMaximo}}</span>
      </div>
    </div>

<div class="bloque-atributos">
  <div class="bloque-titulo">Atributos</div>
  <div class="atributos-grid">
    {{!-- FUERZA --}}
    <div class="atributo-item">
      <label>Fuerza</label>
      <div class="atributo-control">
        <input type="number" name="system.atributos.fuerza" value="{{actor.system.atributos.fuerza}}" min="0" readonly>
        <button type="button" class="btn-up-atr" data-atr="fuerza" data-pago="pp" title="Subir con 4 PP"><i class="fas fa-plus-circle"></i></button>
      </div>
    </div>

    {{!-- VELOCIDAD --}}
    <div class="atributo-item">
      <label>Velocidad</label>
      <div class="atributo-control">
        <input type="number" name="system.atributos.velocidad" value="{{actor.system.atributos.velocidad}}" min="0" readonly>
        <button type="button" class="btn-up-atr" data-atr="velocidad" data-pago="pp" title="Subir con 4 PP"><i class="fas fa-plus-circle"></i></button>
      </div>
    </div>

    {{!-- AGILIDAD --}}
    <div class="atributo-item">
      <label>Agilidad</label>
      <div class="atributo-control">
        <input type="number" name="system.atributos.agilidad" value="{{actor.system.atributos.agilidad}}" min="0" readonly>
        <button type="button" class="btn-up-atr" data-atr="agilidad" data-pago="pd" title="Subir con 4 PD"><i class="fas fa-plus-circle"></i></button>
      </div>
    </div>

    {{!-- INTELIGENCIA --}}
    <div class="atributo-item">
      <label>Inteligencia</label>
      <div class="atributo-control">
        <input type="number" name="system.atributos.inteligencia" value="{{actor.system.atributos.inteligencia}}" min="0" readonly>
        <button type="button" class="btn-up-atr" data-atr="inteligencia" data-pago="pd" title="Subir con 4 PD"><i class="fas fa-plus-circle"></i></button>
      </div>
    </div>
  </div>
</div>

    <div class="bloque-pdc">
      <div class="bloque-titulo">Puntos de Conveniencia</div>
      <div class="pdc-grid">
        <div class="pdc-item">
          <label>PC <small>({{calc.costoPCAccion}}/acc)</small></label>
          <input type="number" name="system.pdc.pc" value="{{actor.system.pdc.pc}}" min="0">
        </div>
        <div class="pdc-item">
          <label>PE</label>
          <input type="number" name="system.pdc.pe" value="{{actor.system.pdc.pe}}" min="0">
        </div>
        <div class="pdc-item">
          <label>PR</label>
          <input type="number" name="system.pdc.pr" value="{{actor.system.pdc.pr}}" min="0">
        </div>
        <div class="pdc-item">
          <label>PD</label>
          <input type="number" name="system.pdc.pd" value="{{actor.system.pdc.pd}}" min="0">
        </div>
        <div class="pdc-item">
          <label>PP</label>
          <input type="number" name="system.pdc.pp" value="{{actor.system.pdc.pp}}" min="0">
        </div>
        <div class="pdc-item">
          <label>S <small>(costo {{calc.costoSuerte}})</small></label>
          <input type="number" name="system.pdc.s" value="{{actor.system.pdc.s}}" min="0">
        </div>
      </div>
    </div>

  </section>

  <nav class="sheet-tabs tabs" data-group="primary">
    <a class="item active" data-tab="datos">📋 Datos</a>
    <a class="item" data-tab="artes">⚔️ Artes &amp; Armas</a>
    <a class="item" data-tab="oficios">🛠️ Oficios</a>
    <a class="item" data-tab="inventario">🎒 Inventario</a>
    <a class="item" data-tab="referencia">📖 Referencia</a>
    <a class="item" data-tab="equipo">🧥 Equipo</a>
  </nav>

  <div class="sheet-body">

    {{!-- TAB DATOS --}}
    <div class="tab active" data-tab="datos">
      <div class="datos-grid">

        <div class="datos-columna">
          <div class="campo-fila">
            <label>Nombre</label>
            <input type="text" name="system.datos.nombre" value="{{actor.system.datos.nombre}}" placeholder="Nombre del personaje">
          </div>
          <div class="campo-fila">
            <label>Procedencia</label>
            <input type="text" name="system.datos.procedencia" value="{{system.datos.procedencia}}" placeholder="Ej: Derla, Rehi">
          </div>
          <div class="campo-fila">
            <label>Edad</label>
            <input type="text" name="system.datos.edad" value="{{actor.system.datos.edad}}">
          </div>
          <div class="campo-fila">
            <label>Clase</label>
            <select name="system.datos.clase">
              <option value="artista"   {{#if (eq actor.system.datos.clase "artista")}}selected{{/if}}>Artista</option>
              <option value="gladiador" {{#if (eq actor.system.datos.clase "gladiador")}}selected{{/if}}>Gladiador</option>
            </select>
          </div>
          <div class="campo-fila">
            <label>Gremio</label>
            <input type="text" name="system.datos.gremio" value="{{actor.system.datos.gremio}}">
          </div>
          <div class="campo-fila">
            <label>Maestro</label>
            <input type="text" name="system.datos.maestro" value="{{actor.system.datos.maestro}}">
          </div>
          <div class="campo-fila">
            <label>Sabio Regidor</label>
            <input type="text" name="system.datos.sabioRegidor" value="{{actor.system.datos.sabioRegidor}}">
          </div>
        </div>

        <div class="datos-columna">
          <div class="campo-fila campo-rango">
            <label>Rango</label>
            <div class="rango-texto">{{calc.rango}}</div>
          </div>
          <div class="campo-fila">
            <label>Descripción</label>
            <textarea name="system.datos.descripcion" rows="7" placeholder="Apariencia, personalidad...">{{actor.system.datos.descripcion}}</textarea>
          </div>
          <div class="campo-fila">
            <label>Erianas</label>
            <div class="erianas-fila">
              <span>Oro</span>
              <input type="number" name="system.erianas.oro" value="{{actor.system.erianas.oro}}" min="0">
              <span>Rubí</span>
              <input type="number" name="system.erianas.rubi" value="{{actor.system.erianas.rubi}}" min="0">
              <span>Diamante</span>
              <input type="number" name="system.erianas.diamante" value="{{actor.system.erianas.diamante}}" min="0">
              <button type="button" class="roll-erianas" title="Tirar erianas iniciales (4d6×10)"><i class="fas fa-dice"></i></button>

              <button type="button" class="btn-abrir-calc" title="Calculadora de Moneda"> <i class="fas fa-calculator"></i> </button>
            </div>
                    
          </div>
        </div>

      </div>
    </div>

    {{!-- TAB ARTES & ARMAS --}}
    <div class="tab" data-tab="artes">
      <div class="seccion-acciones">
        <button type="button" class="item-crear" data-tipo="arte">+ Nueva Arte</button>
        <button type="button" class="item-crear" data-tipo="arma">+ Nueva Arma</button>
        <span class="pa-disponible-badge" title="Puntos de Acción disponibles">⚡ PA: {{actor.system.pa.value}} / {{calc.paMaximo}}</span>
      </div>
      <div class="items-lista">
        {{#each artes}}
        <div class="item-fila arte-fila" data-item-id="{{this.id}}">
          <img src="{{this.img}}" class="item-img">
          <span class="item-nombre">{{this.name}}</span>
          <span class="item-badge nivel-badge">Nv {{this.system.nivel}}</span>
          <span class="item-badge pa-badge" title="PA necesario para usar">{{this.system.costo_pa_real}} PA</span>
          <div class="item-botones">
            <button type="button" class="item-usar" title="Usar arte" data-item-id="{{this.id}}"><i class="fas fa-play"></i></button>
            <button type="button" class="item-editar" title="Editar"><i class="fas fa-edit"></i></button>
            <button type="button" class="item-eliminar" title="Eliminar"><i class="fas fa-trash"></i></button>
          </div>
        </div>
        {{/each}}
        {{#each armas}}
        <div class="item-fila arma-fila" data-item-id="{{this.id}}">
          <img src="{{this.img}}" class="item-img">
          <span class="item-nombre">{{this.name}}</span>
          <span class="item-badge nivel-badge arma">Nv {{this.system.nivel}}</span>
          <span class="item-badge pa-badge" title="PA necesario para usar">{{this.system.costo_pa_real}} PA</span>
          <div class="item-botones">
            <button type="button" class="item-usar" title="Usar arma" data-item-id="{{this.id}}"><i class="fas fa-play"></i></button>
            <button type="button" class="item-editar" title="Editar"><i class="fas fa-edit"></i></button>
            <button type="button" class="item-eliminar" title="Eliminar"><i class="fas fa-trash"></i></button>
          </div>
        </div>
        {{/each}}
        {{#unless artes}}{{#unless armas}}
        <p class="lista-vacia">Sin artes ni armas. Usa los botones de arriba para agregar.</p>
        {{/unless}}{{/unless}}
      </div>
    </div>

    {{!-- TAB OFICIOS --}}
    <div class="tab" data-tab="oficios">
      <p class="nota-oficio">Selecciona 2 oficios al crear la ficha. Gasta 3 PD para reclamar uno. Máximo 7 puntos de oficio.</p>

      {{!-- Selector de oficio del catálogo --}}
      {{#if catalogoOficios.length}}
      <div class="oficio-selector-row">
        <select id="oficio-selector">
          <option value="">— Selecciona un oficio para agregar —</option>
          {{#each catalogoOficios}}
          <option value="{{this.id}}">{{this.nombre}}</option>
          {{/each}}
        </select>
        <button type="button" id="btn-agregar-oficio" type="button"><i class="fas fa-plus"></i> Agregar</button>
      </div>
      {{!-- Panel de vista previa del oficio seleccionado --}}
      <div id="oficio-preview" class="oficio-info-bloque" style="display:none;">
        <div class="oficio-info-nombre"></div>
        <div class="oficio-info-desc"></div>
        <div class="oficio-info-facultades"></div>
      </div>
      {{else}}
      <p class="nota-oficio" style="border-left-color:#8b2e2e;">Ya tienes todos los oficios disponibles.</p>
      {{/if}}

      {{!-- Lista de oficios del personaje --}}
      <div class="items-lista" style="margin-top:10px;">
        {{#each oficios}}
        <div class="item-fila oficio-fila" data-item-id="{{this.id}}">
          <div class="oficio-fila-contenido">
            <div class="oficio-fila-header">
              <span class="item-nombre">{{this.name}}</span>
              {{#if this.actor.system.logro}}<span class="item-badge logro-badge">Logro</span>{{/if}}
            </div>
            {{#if this.actor.system.descripcion}}
            <div class="oficio-fila-desc">{{this.actor.system.descripcion}}</div>
            {{/if}}
            <div class="oficio-pts-row">
              <span class="oficio-pts-label">Puntos de oficio:</span>
              <input type="number" class="oficio-pts-input" name="system.puntos" value="{{this.system.puntos}}" min="0" max="7"
                data-item-id="{{this.id}}" data-dtype="Number">
              <span class="oficio-pts-label">/ {{this.actor.system.maximo}}</span>
            </div>
          </div>
          <div class="item-botones">
            <button type="button" class="item-editar" title="Ver detalles completos"><i class="fas fa-eye"></i></button>
            <button type="button" class="item-eliminar" title="Quitar oficio"><i class="fas fa-trash"></i></button>
          </div>
        </div>
        {{/each}}
        {{#unless oficios}}<p class="lista-vacia">Sin oficios asignados. Usa el selector de arriba para agregar.</p>{{/unless}}
      </div>
    </div>

    {{!-- TAB INVENTARIO --}}
    <div class="tab" data-tab="inventario">
      <div class="inventario-columnas">
        <div class="inv-col">
          <div class="inv-titulo">Objetos <button type="button" class="item-crear" data-tipo="objeto">+</button></div>
          {{#each objetos}}
          <div class="item-fila" data-item-id="{{this.id}}">
            <span class="item-nombre">{{this.name}}</span>
            <span class="item-cant">×{{this.system.cantidad}}</span>
            
            <div class="item-botones">
              <button type="button" class="item-editar"><i class="fas fa-edit"></i></button>
              <button type="button" class="item-eliminar"><i class="fas fa-trash"></i></button>
            </div>
          </div>
          {{/each}}
          {{#unless objetos}}<p class="lista-vacia">Vacío</p>{{/unless}}
        </div>
        <div class="inv-col">
          <div class="inv-titulo">Elixires <button type="button" class="item-crear" data-tipo="elixir">+</button></div>
      {{#each elixires}}
    <div class="item-fila" data-item-id="{{this.id}}">
      <span class="item-nombre">{{this.name}}</span>
      <span class="item-cant">×{{this.system.cantidad}}</span>
      {{#if this.system.ofensivo}}<span class="item-badge">Ofensivo</span>{{/if}}
      
      <div class="item-botones">
        <button type="button" class="item-editar"><i class="fas fa-edit"></i></button>
        <button type="button" class="item-eliminar"><i class="fas fa-trash"></i></button>
      </div>
    </div>
    {{/each}}
          {{#unless elixires}}<p class="lista-vacia">Vacío</p>{{/unless}}
        </div>
      </div>
    </div>

    {{!-- TAB REFERENCIA --}}
    <div class="tab" data-tab="referencia">
      <div class="referencia-grid">

        <div class="ref-bloque">
          <div class="bloque-titulo">Extensión de Estado</div>
          <div class="ext-fila">
            <label>Hambre</label>
            <input type="number" name="system.extensionEstado.hambre.value" value="{{actor.system.extensionEstado.hambre.value}}" min="0" max="9">
            <span>/9</span>
          </div>
          <div class="ext-fila">
            <label>Sed</label>
            <input type="number" name="system.extensionEstado.sed.value" value="{{actor.system.extensionEstado.sed.value}}" min="0" max="9">
            <span>/9</span>
          </div>
          <div class="ext-fila">
            <label>Cansancio</label>
            <input type="number" name="system.extensionEstado.cansancio.value" value="{{actor.system.extensionEstado.cansancio.value}}" min="0" max="9">
            <span>/9</span>
          </div>
          <div class="ext-fila">
            <label>Fatiga</label>
            <input type="number" name="system.extensionEstado.fatiga.value" value="{{actor.system.extensionEstado.fatiga.value}}" min="0" max="9">
            <span>/9</span>
          </div>
          {{#if calc.bonusHeridas}}
          <div class="aviso-estados">⚠️ +{{calc.bonusHeridas}} Pt. Herida por estados activos</div>
          {{/if}}
        </div>

        <div class="ref-bloque">
          <div class="bloque-titulo">Puntos y Marcas</div>
          <div class="punto-fila">
            <label>P.O</label>
            <select name="system.puntosYMarcas.po.estado">
              <option value="I" {{#if (eq actor.system.puntosYMarcas.po.estado "I")}}selected{{/if}}>I</option>
              <option value="A" {{#if (eq actor.system.puntosYMarcas.po.estado "A")}}selected{{/if}}>A</option>
            </select>
            <input type="number" name="system.puntosYMarcas.po.value" value="{{actor.system.puntosYMarcas.po.value}}" min="0" max="3">
            <span>/3</span>
          </div>
          <div class="punto-fila">
            <label>P.OL</label>
            <select name="system.puntosYMarcas.pol.estado">
              <option value="I" {{#if (eq actor.system.puntosYMarcas.pol.estado "I")}}selected{{/if}}>I</option>
              <option value="A" {{#if (eq actor.system.puntosYMarcas.pol.estado "A")}}selected{{/if}}>A</option>
            </select>
            <input type="number" name="system.puntosYMarcas.pol.value" value="{{actor.system.puntosYMarcas.pol.value}}" min="0">
          </div>
          <div class="punto-fila">
            <label>Marca Ctrl.</label>
            <select name="system.puntosYMarcas.marcaControl.estado">
              <option value="I" {{#if (eq actor.system.puntosYMarcas.marcaControl.estado "I")}}selected{{/if}}>I</option>
              <option value="A" {{#if (eq actor.system.puntosYMarcas.marcaControl.estado "A")}}selected{{/if}}>A</option>
            </select>
            <input type="number" name="system.puntosYMarcas.marcaControl.value" value="{{actor.system.puntosYMarcas.marcaControl.value}}" min="0" max="6">
            <span>/6</span>
          </div>
        </div>

        <div class="ref-bloque">
          <div class="bloque-titulo">Reglas Rápidas</div>
          <ul class="reglas-lista">
            <li>1, 3, 5 = aciertos &nbsp;|&nbsp; 2, 4, 6 = pérdidas</li>
            <li>Cada 2 estados = +1 Pt. Herida</li>
            <li>Cada 4 Pt. Herida = −1 Pt. Salud</li>
            <li>9 PE = −1 Pt. Herida &nbsp;|&nbsp; 9 PE = +1 Pt. Salud</li>
            <li>Usar Arte/Arma = +1 Cansancio</li>
            <li>Rebote: arte estando herido (8+ Pt. Herida)</li>
            <li>Suma dados &gt;12 = Buena suerte</li>
            <li>Suerte: 1 vez cada 4 turnos</li>
            <li>Arte/Arma Nv.4 = +2 aciertos al inicio del combate</li>
            <li>+2 PdC al resolver conflicto interno</li>
          </ul>
        </div>

        <div class="ref-bloque">
          <div class="bloque-titulo">Tabla de Rangos</div>
          <table class="rangos-tabla">
            <tr><th>Rango</th><th>PV mín.</th><th>PC/acc</th></tr>
            <tr {{#if (eq calc.rango "Astrei")}}class="rango-actual"{{/if}}><td>Astrei</td><td>15</td><td>15</td></tr>
            <tr {{#if (eq calc.rango "Breintin")}}class="rango-actual"{{/if}}><td>Breintin</td><td>74</td><td>20</td></tr>
            <tr {{#if (eq calc.rango "Sedrein")}}class="rango-actual"{{/if}}><td>Sedrein</td><td>146</td><td>25</td></tr>
            <tr {{#if (eq calc.rango "Wonrixay")}}class="rango-actual"{{/if}}><td>Wonrixay</td><td>231</td><td>30</td></tr>
            <tr {{#if (eq calc.rango "Lait Betsu")}}class="rango-actual"{{/if}}><td>Lait Betsu</td><td>329</td><td>35</td></tr>
            <tr {{#if (eq calc.rango "Leyenda")}}class="rango-actual"{{/if}}><td>Leyenda</td><td>440</td><td>40</td></tr>
            <tr {{#if (eq calc.rango "Lairazul")}}class="rango-actual"{{/if}}><td>Lairazul</td><td>564</td><td>45</td></tr>
          </table>
        </div>

      </div>
    </div>

    {{!-- TAB EQUIPO --}}
    <div class="tab" data-tab="equipo">
      <div class="seccion-acciones">
        <button type="button" class="item-crear" data-tipo="equipo">+ Agregar Equipo</button>
      </div>
      <div class="items-lista">
        {{#each equipos}}
        <div class="item-fila" data-item-id="{{this.id}}">
          <img src="{{this.img}}" class="item-img">
          <span class="item-nombre">{{this.name}}</span>
          <span class="item-badge">{{this.actor.system.slot}}</span>
          {{#if this.actor.system.reduccion_dano}}<span class="item-badge reduccion">-{{this.actor.system.reduccion_dano}} dmg</span>{{/if}}
          <div class="item-botones">
            <button type="button" class="item-editar"><i class="fas fa-edit"></i></button>
            <button type="button" class="item-eliminar"><i class="fas fa-trash"></i></button>
          </div>
        </div>
        {{/each}}
        {{#unless equipos}}<p class="lista-vacia">Sin equipo. Agrega con el botón de arriba.</p>{{/unless}}
      </div>
    </div>

  </div>
</form>
