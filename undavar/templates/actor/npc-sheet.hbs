<form class="undavar-sheet npc" autocomplete="off">
  <header class="sheet-header">
    <img class="actor-imagen" src="{{actor.img}}" data-edit="img" title="{{actor.name}}">
    <div class="npc-datos">
      <input type="text" class="actor-nombre-input" name="name" value="{{actor.name}}" placeholder="Nombre del NPC">
      <div class="campo-fila">
        <label>Raza / Tipo</label>
        <input type="text" name="system.datos.raza" value="{{actor.system.datos.raza}}" placeholder="Ej: Lethur, Ser salvaje">
      </div>
      <div class="campo-fila">
        <label>Descripción</label>
        <textarea name="system.datos.descripcion" rows="3">{{actor.system.datos.descripcion}}</textarea>
      </div>
    </div>
  </header>

  <section class="estado-atributos-bar">
    <div class="bloque-estado">
      <div class="bloque-titulo">Estado</div>
      <div class="estado-fila">
        <label>Pt. Herida</label>
        <input type="number" name="system.estado.ptHerida.value" value="{{actor.system.estado.ptHerida.value}}" min="0" max="8">
        <span>/8</span>
      </div>
      <div class="estado-fila">
        <label>Pt. Salud</label>
        <input type="number" name="system.estado.ptSalud.value" value="{{actor.system.estado.ptSalud.value}}" min="0" max="8">
        <span>/8</span>
      </div>
      <div class="estado-fila">
        <label>PA</label>
        <input type="number" name="system.pa.value" value="{{actor.system.pa.value}}" min="0" max="6">
        <span>/ 6</span>
      </div>
    </div>
    <div class="bloque-atributos">
      <div class="bloque-titulo">Atributos</div>
      <div class="atributos-grid">
        <div class="atributo-item"><label>Fuerza</label><input type="number" name="system.atributos.fuerza" value="{{actor.system.atributos.fuerza}}" min="0"></div>
        <div class="atributo-item"><label>Velocidad</label><input type="number" name="system.atributos.velocidad" value="{{actor.system.atributos.velocidad}}" min="0"></div>
        <div class="atributo-item"><label>Agilidad</label><input type="number" name="system.atributos.agilidad" value="{{actor.system.atributos.agilidad}}" min="0"></div>
        <div class="atributo-item"><label>Inteligencia</label><input type="number" name="system.atributos.inteligencia" value="{{actor.system.atributos.inteligencia}}" min="0"></div>
      </div>
    </div>
  </section>

  <div class="npc-acciones">
    <button type="button" class="roll-estandar"><i class="fas fa-dice-d6"></i> Tirada</button>
    <button type="button" class="roll-ataque"><i class="fas fa-fist-raised"></i> Ataque</button>
  </div>

  <div class="artes-seccion">
    <div class="seccion-cabecera">
      <h3>Artes / Habilidades</h3>
      <button type="button" class="item-crear" data-tipo="arte">+ Arte</button>
      <button type="button" class="item-crear" data-tipo="arma">+ Arma</button>
    </div>
    {{#each artes as |item|}}
    <div class="item-fila" data-item-id="{{item.id}}">
      <span class="item-nombre">{{item.name}}</span>
      <span class="item-badge">Nv {{item.system.nivel}}</span>
      <button type="button" class="item-editar"><i class="fas fa-edit"></i></button>
      <button type="button" class="item-eliminar"><i class="fas fa-trash"></i></button>
    </div>
    {{/each}}
    {{#if (eq artes.length 0)}}<p class="lista-vacia">Sin habilidades.</p>{{/if}}
  </div>
</form>