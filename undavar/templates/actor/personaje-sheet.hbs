<div class="undavar-sheet personaje">

  <header class="sheet-header">
    <div class="header-izquierda">
      <img class="actor-imagen" src="{{actor.img}}" data-edit="img" title="{{actor.name}}">
      <div class="nombre-bloque">
        <h1 class="actor-nombre">{{actor.name}}</h1>
        <div class="rango-display">{{calc.rango}}</div>
        <div class="pv-bloque">
          <label>PV (#)</label>
          <input type="number" name="system.pv.value" value="{{system.pv.value}}" min="0" max="564">
          <span class="pv-max">/ 564</span>
        </div>
      </div>
    </div>
    <div class="header-tiradas">
      <button class="roll-estandar" data-label="Tirada estándar"><i class="fas fa-dice-d6"></i> Tirada</button>
      <button class="roll-ataque" data-label="Ataque"><i class="fas fa-fist-raised"></i> Ataque</button>
      <button class="roll-rebote"><i class="fas fa-bolt"></i> Rebote</button>
      <button class="roll-despertar"><i class="fas fa-sun"></i> Despertar</button>
    </div>
  </header>

  <section class="estado-atributos-bar">

    <div class="bloque-estado">
      <div class="bloque-titulo">Estado</div>
      <div class="estado-fila">
        <label>Pt. Herida</label>
        <input type="number" name="system.estado.ptHerida.value" value="{{system.estado.ptHerida.value}}" min="0" max="8">
        <span class="estado-max">/8</span>
        {{#if calc.saludPorHeridas}}<span class="aviso-herida">(-{{calc.saludPorHeridas}} Salud)</span>{{/if}}
      </div>
      <div class="estado-fila">
        <label>Pt. Salud</label>
        <input type="number" name="system.estado.ptSalud.value" value="{{system.estado.ptSalud.value}}" min="0" max="8">
        <span class="estado-max">/8</span>
      </div>
      <div class="estado-fila">
        <label>PA</label>
        <input type="number" name="system.pa.value" value="{{system.pa.value}}" min="0" max="{{calc.paMaximo}}">
        <span class="estado-max">/{{calc.paMaximo}}</span>
      </div>
    </div>

    <div class="bloque-atributos">
      <div class="bloque-titulo">Atributos</div>
      <div class="atributos-grid">
        <div class="atributo-item">
          <label>Fuerza</label>
          <input type="number" name="system.atributos.fuerza" value="{{system.atributos.fuerza}}" min="0">
        </div>
        <div class="atributo-item">
          <label>Velocidad</label>
          <input type="number" name="system.atributos.velocidad" value="{{system.atributos.velocidad}}" min="0">
        </div>
        <div class="atributo-item">
          <label>Agilidad</label>
          <input type="number" name="system.atributos.agilidad" value="{{system.atributos.agilidad}}" min="0">
        </div>
        <div class="atributo-item">
          <label>Inteligencia</label>
          <input type="number" name="system.atributos.inteligencia" value="{{system.atributos.inteligencia}}" min="0">
        </div>
      </div>
    </div>

    <div class="bloque-pdc">
      <div class="bloque-titulo">Puntos de Conveniencia</div>
      <div class="pdc-grid">
        <div class="pdc-item">
          <label>PC <small>({{calc.costoPCAccion}}/acc)</small></label>
          <input type="number" name="system.pdc.pc" value="{{system.pdc.pc}}" min="0">
        </div>
        <div class="pdc-item">
          <label>PE</label>
          <input type="number" name="system.pdc.pe" value="{{system.pdc.pe}}" min="0">
        </div>
        <div class="pdc-item">
          <label>PR</label>
          <input type="number" name="system.pdc.pr" value="{{system.pdc.pr}}" min="0">
        </div>
        <div class="pdc-item">
          <label>PD</label>
          <input type="number" name="system.pdc.pd" value="{{system.pdc.pd}}" min="0">
        </div>
        <div class="pdc-item">
          <label>PP</label>
          <input type="number" name="system.pdc.pp" value="{{system.pdc.pp}}" min="0">
        </div>
        <div class="pdc-item">
          <label>S <small>(costo {{calc.costoSuerte}})</small></label>
          <input type="number" name="system.pdc.s" value="{{system.pdc.s}}" min="0">
        </div>
      </div>
    </div>

  </section>

  <nav class="sheet-tabs tabs" data-group="primary">
    <a class="item active" data-tab="datos">📋 Datos</a>
    <a class="item" data-tab="artes">⚔️ Artes &amp; Armas</a>
    <a class="item" data-tab="oficios">🛠️ Oficios</a>
    <a class="item" data-tab="inventario">🎒 Inventario</a>
    <a class="item" data-tab="referencia">📖 Referencia</a>
    <a class="item" data-tab="equipo">🧥 Equipo</a>
  </nav>

  <div class="sheet-body">

    {{!-- TAB DATOS --}}
    <div class="tab active" data-tab="datos">
      <div class="datos-grid">

        <div class="datos-columna">
          <div class="campo-fila">
            <label>Nombre</label>
            <input type="text" name="system.datos.nombre" value="{{system.datos.nombre}}" placeholder="Nombre del personaje">
          </div>
          <div class="campo-fila">
            <label>Procedencia</label>
            <input type="text" name="system.datos.procedencia" value="{{system.datos.procedencia}}" placeholder="Ej: Derla, Rehi">
          </div>
          <div class="campo-fila">
            <label>Edad</label>
            <input type="text" name="system.datos.edad" value="{{system.datos.edad}}">
          </div>
          <div class="campo-fila">
            <label>Clase</label>
            <select name="system.datos.clase">
              <option value="artista"   {{#if (eq system.datos.clase "artista")}}selected{{/if}}>Artista</option>
              <option value="gladiador" {{#if (eq system.datos.clase "gladiador")}}selected{{/if}}>Gladiador</option>
            </select>
          </div>
          <div class="campo-fila">
            <label>Gremio</label>
            <input type="text" name="system.datos.gremio" value="{{system.datos.gremio}}">
          </div>
          <div class="campo-fila">
            <label>Maestro</label>
            <input type="text" name="system.datos.maestro" value="{{system.datos.maestro}}">
          </div>
          <div class="campo-fila">
            <label>Sabio Regidor</label>
            <input type="text" name="system.datos.sabioRegidor" value="{{system.datos.sabioRegidor}}">
          </div>
        </div>

        <div class="datos-columna">
          <div class="campo-fila campo-rango">
            <label>Rango</label>
            <div class="rango-texto">{{calc.rango}}</div>
          </div>
          <div class="campo-fila">
            <label>Descripción</label>
            <textarea name="system.datos.descripcion" rows="7" placeholder="Apariencia, personalidad...">{{system.datos.descripcion}}</textarea>
          </div>
          <div class="campo-fila">
            <label>Erianas</label>
            <div class="erianas-fila">
              <span>Oro</span>
              <input type="number" name="system.erianas.oro" value="{{system.erianas.oro}}" min="0">
              <span>Rubí</span>
              <input type="number" name="system.erianas.rubi" value="{{system.erianas.rubi}}" min="0">
              <span>Diamante</span>
              <input type="number" name="system.erianas.diamante" value="{{system.erianas.diamante}}" min="0">
              <button class="roll-erianas" title="Tirar erianas iniciales (4d6×10)"><i class="fas fa-dice"></i></button>
            </div>
          </div>
        </div>

      </div>
    </div>

    {{!-- TAB ARTES & ARMAS --}}
    <div class="tab" data-tab="artes">
      <div class="seccion-acciones">
        <button class="item-crear" data-tipo="arte">+ Nueva Arte</button>
        <button class="item-crear" data-tipo="arma">+ Nueva Arma</button>
      </div>
      <div class="items-lista">
        {{#each artes}}
        <div class="item-fila arte-fila" data-item-id="{{this.id}}">
          <img src="{{this.img}}" class="item-img">
          <span class="item-nombre">{{this.name}}</span>
          <span class="item-badge nivel-badge">Nv {{this.system.nivel}}</span>
          <span class="item-badge pa-badge">{{this.system.costo_pa}} PA</span>
          <div class="item-botones">
            <button class="item-usar" title="Usar arte"><i class="fas fa-play"></i></button>
            <button class="item-editar" title="Editar"><i class="fas fa-edit"></i></button>
            <button class="item-eliminar" title="Eliminar"><i class="fas fa-trash"></i></button>
          </div>
        </div>
        {{/each}}
        {{#each armas}}
        <div class="item-fila arma-fila" data-item-id="{{this.id}}">
          <img src="{{this.img}}" class="item-img">
          <span class="item-nombre">{{this.name}}</span>
          <span class="item-badge nivel-badge arma">Nv {{this.system.nivel}}</span>
          <span class="item-badge pa-badge">{{this.system.costo_pa}} PA</span>
          <div class="item-botones">
            <button class="item-usar" title="Usar arma"><i class="fas fa-play"></i></button>
            <button class="item-editar" title="Editar"><i class="fas fa-edit"></i></button>
            <button class="item-eliminar" title="Eliminar"><i class="fas fa-trash"></i></button>
          </div>
        </div>
        {{/each}}
        {{#unless artes}}{{#unless armas}}
        <p class="lista-vacia">Sin artes ni armas. Usa los botones de arriba para agregar.</p>
        {{/unless}}{{/unless}}
      </div>
    </div>

    {{!-- TAB OFICIOS --}}
    <div class="tab" data-tab="oficios">
      <div class="seccion-acciones">
        <button class="item-crear" data-tipo="oficio">+ Agregar Oficio</button>
      </div>
      <p class="nota-oficio">Selecciona 2 oficios al crear la ficha. Gasta 3 PD para reclamar uno. Máximo 7 puntos de oficio.</p>
      <div class="items-lista">
        {{#each oficios}}
        <div class="item-fila oficio-fila" data-item-id="{{this.id}}">
          <img src="{{this.img}}" class="item-img">
          <span class="item-nombre">{{this.name}}</span>
          {{#if this.system.logro}}<span class="item-badge logro-badge">Logro</span>{{/if}}
          <span class="item-badge pts-badge">{{this.system.puntos}}/{{this.system.maximo}} pts</span>
          <div class="item-botones">
            <button class="item-editar"><i class="fas fa-edit"></i></button>
            <button class="item-eliminar"><i class="fas fa-trash"></i></button>
          </div>
        </div>
        {{/each}}
        {{#unless oficios}}<p class="lista-vacia">Sin oficios asignados.</p>{{/unless}}
      </div>
    </div>

    {{!-- TAB INVENTARIO --}}
    <div class="tab" data-tab="inventario">
      <div class="inventario-columnas">
        <div class="inv-col">
          <div class="inv-titulo">Objetos <button class="item-crear" data-tipo="objeto">+</button></div>
          {{#each objetos}}
          <div class="item-fila" data-item-id="{{this.id}}">
            <span class="item-nombre">{{this.name}}</span>
            <span class="item-cant">×{{this.system.cantidad}}</span>
            <button class="item-editar"><i class="fas fa-edit"></i></button>
            <button class="item-eliminar"><i class="fas fa-trash"></i></button>
          </div>
          {{/each}}
          {{#unless objetos}}<p class="lista-vacia">Vacío</p>{{/unless}}
        </div>
        <div class="inv-col">
          <div class="inv-titulo">Elixires <button class="item-crear" data-tipo="elixir">+</button></div>
          {{#each elixires}}
          <div class="item-fila" data-item-id="{{this.id}}">
            <span class="item-nombre">{{this.name}}</span>
            <span class="item-cant">×{{this.system.cantidad}}</span>
            {{#if this.system.ofensivo}}<span class="item-badge">Ofensivo</span>{{/if}}
            <button class="item-editar"><i class="fas fa-edit"></i></button>
            <button class="item-eliminar"><i class="fas fa-trash"></i></button>
          </div>
          {{/each}}
          {{#unless elixires}}<p class="lista-vacia">Vacío</p>{{/unless}}
        </div>
      </div>
    </div>

    {{!-- TAB REFERENCIA --}}
    <div class="tab" data-tab="referencia">
      <div class="referencia-grid">

        <div class="ref-bloque">
          <div class="bloque-titulo">Extensión de Estado</div>
          <div class="ext-fila">
            <label>Hambre</label>
            <input type="number" name="system.extensionEstado.hambre.value" value="{{system.extensionEstado.hambre.value}}" min="0" max="9">
            <span>/9</span>
          </div>
          <div class="ext-fila">
            <label>Sed</label>
            <input type="number" name="system.extensionEstado.sed.value" value="{{system.extensionEstado.sed.value}}" min="0" max="9">
            <span>/9</span>
          </div>
          <div class="ext-fila">
            <label>Cansancio</label>
            <input type="number" name="system.extensionEstado.cansancio.value" value="{{system.extensionEstado.cansancio.value}}" min="0" max="9">
            <span>/9</span>
          </div>
          <div class="ext-fila">
            <label>Fatiga</label>
            <input type="number" name="system.extensionEstado.fatiga.value" value="{{system.extensionEstado.fatiga.value}}" min="0" max="9">
            <span>/9</span>
          </div>
          {{#if calc.bonusHeridas}}
          <div class="aviso-estados">⚠️ +{{calc.bonusHeridas}} Pt. Herida por estados activos</div>
          {{/if}}
        </div>

        <div class="ref-bloque">
          <div class="bloque-titulo">Puntos y Marcas</div>
          <div class="punto-fila">
            <label>P.O</label>
            <select name="system.puntosYMarcas.po.estado">
              <option value="I" {{#if (eq system.puntosYMarcas.po.estado "I")}}selected{{/if}}>I</option>
              <option value="A" {{#if (eq system.puntosYMarcas.po.estado "A")}}selected{{/if}}>A</option>
            </select>
            <input type="number" name="system.puntosYMarcas.po.value" value="{{system.puntosYMarcas.po.value}}" min="0" max="3">
            <span>/3</span>
          </div>
          <div class="punto-fila">
            <label>P.OL</label>
            <select name="system.puntosYMarcas.pol.estado">
              <option value="I" {{#if (eq system.puntosYMarcas.pol.estado "I")}}selected{{/if}}>I</option>
              <option value="A" {{#if (eq system.puntosYMarcas.pol.estado "A")}}selected{{/if}}>A</option>
            </select>
            <input type="number" name="system.puntosYMarcas.pol.value" value="{{system.puntosYMarcas.pol.value}}" min="0">
          </div>
          <div class="punto-fila">
            <label>Marca Ctrl.</label>
            <select name="system.puntosYMarcas.marcaControl.estado">
              <option value="I" {{#if (eq system.puntosYMarcas.marcaControl.estado "I")}}selected{{/if}}>I</option>
              <option value="A" {{#if (eq system.puntosYMarcas.marcaControl.estado "A")}}selected{{/if}}>A</option>
            </select>
            <input type="number" name="system.puntosYMarcas.marcaControl.value" value="{{system.puntosYMarcas.marcaControl.value}}" min="0" max="6">
            <span>/6</span>
          </div>
        </div>

        <div class="ref-bloque">
          <div class="bloque-titulo">Reglas Rápidas</div>
          <ul class="reglas-lista">
            <li>1, 3, 5 = aciertos &nbsp;|&nbsp; 2, 4, 6 = pérdidas</li>
            <li>Cada 2 estados = +1 Pt. Herida</li>
            <li>Cada 4 Pt. Herida = −1 Pt. Salud</li>
            <li>9 PE = −1 Pt. Herida &nbsp;|&nbsp; 9 PE = +1 Pt. Salud</li>
            <li>Usar Arte/Arma = +1 Cansancio</li>
            <li>Rebote: arte estando herido (8+ Pt. Herida)</li>
            <li>Suma dados &gt;12 = Buena suerte</li>
            <li>Suerte: 1 vez cada 4 turnos</li>
            <li>Arte/Arma Nv.4 = +2 aciertos al inicio del combate</li>
            <li>+2 PdC al resolver conflicto interno</li>
          </ul>
        </div>

        <div class="ref-bloque">
          <div class="bloque-titulo">Tabla de Rangos</div>
          <table class="rangos-tabla">
            <tr><th>Rango</th><th>PV mín.</th><th>PC/acc</th></tr>
            <tr {{#if (eq calc.rango "Astrei")}}class="rango-actual"{{/if}}><td>Astrei</td><td>15</td><td>15</td></tr>
            <tr {{#if (eq calc.rango "Breintin")}}class="rango-actual"{{/if}}><td>Breintin</td><td>74</td><td>20</td></tr>
            <tr {{#if (eq calc.rango "Sedrein")}}class="rango-actual"{{/if}}><td>Sedrein</td><td>146</td><td>25</td></tr>
            <tr {{#if (eq calc.rango "Wonrixay")}}class="rango-actual"{{/if}}><td>Wonrixay</td><td>231</td><td>30</td></tr>
            <tr {{#if (eq calc.rango "Lait Betsu")}}class="rango-actual"{{/if}}><td>Lait Betsu</td><td>329</td><td>35</td></tr>
            <tr {{#if (eq calc.rango "Leyenda")}}class="rango-actual"{{/if}}><td>Leyenda</td><td>440</td><td>40</td></tr>
            <tr {{#if (eq calc.rango "Lairazul")}}class="rango-actual"{{/if}}><td>Lairazul</td><td>564</td><td>45</td></tr>
          </table>
        </div>

      </div>
    </div>

    {{!-- TAB EQUIPO --}}
    <div class="tab" data-tab="equipo">
      <div class="seccion-acciones">
        <button class="item-crear" data-tipo="equipo">+ Agregar Equipo</button>
      </div>
      <div class="items-lista">
        {{#each equipos}}
        <div class="item-fila" data-item-id="{{this.id}}">
          <img src="{{this.img}}" class="item-img">
          <span class="item-nombre">{{this.name}}</span>
          <span class="item-badge">{{this.system.slot}}</span>
          {{#if this.system.reduccion_dano}}<span class="item-badge reduccion">-{{this.system.reduccion_dano}} dmg</span>{{/if}}
          <div class="item-botones">
            <button class="item-editar"><i class="fas fa-edit"></i></button>
            <button class="item-eliminar"><i class="fas fa-trash"></i></button>
          </div>
        </div>
        {{/each}}
        {{#unless equipos}}<p class="lista-vacia">Sin equipo. Agrega con el botón de arriba.</p>{{/unless}}
      </div>
    </div>

  </div>
</div>
