<div class="undavar-sheet item-sheet">
  <header class="item-header">
    <img class="item-imagen" src="{{item.img}}" data-edit="img" title="{{item.name}}">
    <div class="item-nombre-tipo">
      <input type="text" class="item-nombre-input" name="name" value="{{item.name}}">
      <span class="item-tipo-badge tipo-{{item.type}}">
        {{#if (eq item.type "arte")}}Arte{{/if}}
        {{#if (eq item.type "arma")}}Arma{{/if}}
        {{#if (eq item.type "objeto")}}Objeto{{/if}}
        {{#if (eq item.type "elixir")}}Elixir{{/if}}
        {{#if (eq item.type "oficio")}}Oficio{{/if}}
        {{#if (eq item.type "equipo")}}Equipo{{/if}}
      </span>
    </div>
  </header>

  <div class="item-body">

    {{!-- ARTE --}}
    {{#if (eq item.type "arte")}}
    <div class="campo-fila">
      <label>Tipo</label>
      <select name="system.tipo">
        <option value="artista" {{#if (eq system.tipo "artista")}}selected{{/if}}>Solo Artista</option>
        <option value="gladiador" {{#if (eq system.tipo "gladiador")}}selected{{/if}}>Solo Gladiador</option>
        <option value="ambos" {{#if (eq system.tipo "ambos")}}selected{{/if}}>Ambos</option>
      </select>
    </div>
    <div class="campo-fila">
      <label>Nivel</label>
      <select name="system.nivel">
        {{#each niveles as |n|}}<option value="{{n}}" {{#if (eq ../system.nivel n)}}selected{{/if}}>{{n}}</option>{{/each}}
      </select>
      <span class="nivel-info">PA: {{costoPANivel}} | PV para subir: {{costoPVNivel}} | Bonus: +{{bonusNivel}}</span>
    </div>
    <div class="campo-fila">
      <label>Invocación / Frase</label>
      <textarea name="system.invocacion" rows="3" placeholder="Ej: Yo, [Nombre], ordeno a la naturaleza...">{{system.invocacion}}</textarea>
    </div>
    <div class="campo-fila">
      <label>Descripción / Efecto</label>
      <textarea name="system.descripcion" rows="4" placeholder="Describe el efecto del arte...">{{system.descripcion}}</textarea>
    </div>
    <div class="campo-fila">
      <label>Notas</label>
      <textarea name="system.notas" rows="2">{{system.notas}}</textarea>
    </div>
    {{/if}}

    {{!-- ARMA --}}
    {{#if (eq item.type "arma")}}
    <div class="campo-fila">
      <label>Nivel</label>
      <select name="system.nivel">
        {{#each niveles as |n|}}<option value="{{n}}" {{#if (eq ../system.nivel n)}}selected{{/if}}>{{n}}</option>{{/each}}
      </select>
      <span class="nivel-info">PA: {{costoPANivel}} | PV para subir: {{costoPVNivel}} | Bonus: +{{bonusNivel}}</span>
    </div>
    <div class="campo-fila">
      <label>Descripción / Poder</label>
      <textarea name="system.descripcion" rows="4" placeholder="Describe las propiedades del arma...">{{system.descripcion}}</textarea>
    </div>
    <div class="campo-fila">
      <label>Sellos (si aplica)</label>
      <textarea name="system.sellos" rows="3" placeholder="Describe los sellos del arma...">{{system.sellos}}</textarea>
    </div>
    <div class="campo-fila">
      <label>Notas</label>
      <textarea name="system.notas" rows="2">{{system.notas}}</textarea>
    </div>
    {{/if}}

    {{!-- OBJETO --}}
    {{#if (eq item.type "objeto")}}
    <div class="campo-fila">
      <label>Efecto</label>
      <textarea name="system.efecto" rows="3">{{system.efecto}}</textarea>
    </div>
    <div class="campos-linea">
      <div class="campo-fila"><label>Duración</label><input type="text" name="system.duracion" value="{{system.duracion}}" placeholder="Ej: 3 minutos"></div>
      <div class="campo-fila"><label>Enfriamiento</label><input type="text" name="system.enfriamiento" value="{{system.enfriamiento}}"></div>
      <div class="campo-fila"><label>Cantidad</label><input type="number" name="system.cantidad" value="{{system.cantidad}}" min="0"></div>
    </div>
    <div class="campos-linea precios">
      <div class="campo-fila"><label>Precio Oro</label><input type="number" name="system.precio_oro" value="{{system.precio_oro}}" min="0"></div>
      <div class="campo-fila"><label>Precio Rubí</label><input type="number" name="system.precio_rubi" value="{{system.precio_rubi}}" min="0"></div>
      <div class="campo-fila"><label>Precio Diamante</label><input type="number" name="system.precio_diamante" value="{{system.precio_diamante}}" min="0"></div>
    </div>
    <div class="campo-fila"><label>Notas</label><textarea name="system.notas" rows="2">{{system.notas}}</textarea></div>
    {{/if}}

    {{!-- ELIXIR --}}
    {{#if (eq item.type "elixir")}}
    <div class="campo-fila">
      <label>Efecto</label>
      <textarea name="system.efecto" rows="3">{{system.efecto}}</textarea>
    </div>
    <div class="campos-linea">
      <div class="campo-fila"><label>Duración</label><input type="text" name="system.duracion" value="{{system.duracion}}"></div>
      <div class="campo-fila">
        <label>Nivel</label>
        <select name="system.nivel">
          <option value="0" {{#if (eq system.nivel 0)}}selected{{/if}}>Sin nivel</option>
          {{#each niveles as |n|}}<option value="{{n}}" {{#if (eq ../system.nivel n)}}selected{{/if}}>{{n}}</option>{{/each}}
        </select>
      </div>
      <div class="campo-fila"><label>Cantidad</label><input type="number" name="system.cantidad" value="{{system.cantidad}}" min="0"></div>
    </div>
    <div class="campo-fila">
      <label>¿Ofensivo?</label>
      <input type="checkbox" name="system.ofensivo" {{#if system.ofensivo}}checked{{/if}}>
      <small>(Los elixires ofensivos se usan como armas)</small>
    </div>
    <div class="campos-linea precios">
      <div class="campo-fila"><label>Oro</label><input type="number" name="system.precio_oro" value="{{system.precio_oro}}" min="0"></div>
      <div class="campo-fila"><label>Rubí</label><input type="number" name="system.precio_rubi" value="{{system.precio_rubi}}" min="0"></div>
      <div class="campo-fila"><label>Diamante</label><input type="number" name="system.precio_diamante" value="{{system.precio_diamante}}" min="0"></div>
    </div>
    <div class="campo-fila"><label>Descripción</label><textarea name="system.descripcion" rows="2">{{system.descripcion}}</textarea></div>
    {{/if}}

    {{!-- OFICIO --}}
    {{#if (eq item.type "oficio")}}
    <div class="campos-linea">
      <div class="campo-fila">
        <label>Puntos de oficio</label>
        <input type="number" name="system.puntos" value="{{system.puntos}}" min="0" max="7">
        <span>/ {{system.maximo}}</span>
      </div>
      <div class="campo-fila">
        <label>¿De logro?</label>
        <input type="checkbox" name="system.logro" {{#if system.logro}}checked{{/if}}>
      </div>
      {{#if system.logro}}
      <div class="campo-fila">
        <label>P.OL requeridos</label>
        <input type="number" name="system.pol_requeridos" value="{{system.pol_requeridos}}" min="1">
      </div>
      {{/if}}
    </div>
    <div class="campo-fila">
      <label>Descripción</label>
      <textarea name="system.descripcion" rows="3" placeholder="¿Qué hace este oficio?">{{system.descripcion}}</textarea>
    </div>
    <div class="campo-fila">
      <label>Facultades</label>
      <textarea name="system.facultades" rows="5" placeholder="Lista las facultades del oficio...">{{system.facultades}}</textarea>
    </div>
    <div class="bloque-titulo">Bonificaciones del oficio</div>
    <div class="bonos-grid">
      <div class="campo-fila"><label>PE</label><input type="number" name="system.bonos.pe" value="{{system.bonos.pe}}"></div>
      <div class="campo-fila"><label>PP</label><input type="number" name="system.bonos.pp" value="{{system.bonos.pp}}"></div>
      <div class="campo-fila"><label>PD</label><input type="number" name="system.bonos.pd" value="{{system.bonos.pd}}"></div>
      <div class="campo-fila"><label>PC</label><input type="number" name="system.bonos.pc" value="{{system.bonos.pc}}"></div>
      <div class="campo-fila"><label>PR</label><input type="number" name="system.bonos.pr" value="{{system.bonos.pr}}"></div>
      <div class="campo-fila"><label>S</label><input type="number" name="system.bonos.s" value="{{system.bonos.s}}"></div>
      <div class="campo-fila"><label>Fuerza</label><input type="number" name="system.bonos.fuerza" value="{{system.bonos.fuerza}}"></div>
      <div class="campo-fila"><label>Velocidad</label><input type="number" name="system.bonos.velocidad" value="{{system.bonos.velocidad}}"></div>
      <div class="campo-fila"><label>Agilidad</label><input type="number" name="system.bonos.agilidad" value="{{system.bonos.agilidad}}"></div>
      <div class="campo-fila"><label>Inteligencia</label><input type="number" name="system.bonos.inteligencia" value="{{system.bonos.inteligencia}}"></div>
      <div class="campo-fila"><label>+Salud</label><input type="number" name="system.bonos.salud" value="{{system.bonos.salud}}"></div>
    </div>
    {{/if}}

    {{!-- EQUIPO --}}
    {{#if (eq item.type "equipo")}}
    <div class="campo-fila">
      <label>Slot de equipo</label>
      <select name="system.slot">
        {{#each slots as |label key|}}
        <option value="{{key}}" {{#if (eq ../system.slot key)}}selected{{/if}}>{{label}}</option>
        {{/each}}
      </select>
    </div>
    <div class="campo-fila">
      <label>Reducción de daño</label>
      <input type="number" name="system.reduccion_dano" value="{{system.reduccion_dano}}" min="0">
    </div>
    <div class="campo-fila">
      <label>Efecto / Encanto especial</label>
      <textarea name="system.efecto" rows="3">{{system.efecto}}</textarea>
    </div>
    <div class="campos-linea precios">
      <div class="campo-fila"><label>Oro</label><input type="number" name="system.precio_oro" value="{{system.precio_oro}}" min="0"></div>
      <div class="campo-fila"><label>Rubí</label><input type="number" name="system.precio_rubi" value="{{system.precio_rubi}}" min="0"></div>
      <div class="campo-fila"><label>Diamante</label><input type="number" name="system.precio_diamante" value="{{system.precio_diamante}}" min="0"></div>
    </div>
    <div class="campo-fila"><label>Descripción</label><textarea name="system.descripcion" rows="3">{{system.descripcion}}</textarea></div>
    <div class="campo-fila"><label>Notas</label><textarea name="system.notas" rows="2">{{system.notas}}</textarea></div>
    {{/if}}

  </div>
</div>
